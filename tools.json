    {
        "type": "function",
        "function": {
            "server_file": "mcp_server/sys_server.py",
            "name": "list_dir_item",
            "description": "列出指定目录下的文件或目录，返回文件或目录的详细信息列表\n参数：\n    dir_path:       目录路径，默认为当前目录\n    search_mode:    查询模式，默认为 file，表示查询文件，可选项为 file, dir，all；其中 all 表示所有文件和目录，传入其他参数则只会返回文件\n    file_type:      文件类型（例如：.py），默认为 None，表示所有文件以及其子目录下的所有文件\n    depth:          整数类型，递归深度，0 表示不递归（即当前目录），1 表示一级子目录，以此类推，默认为 0\n返回：\n    文件或目录信息列表，每个元素是一个字典，包含以下字段：\n        - path: 完整路径字符串\n        - type: 类型，\"file\" 或 \"dir\"\n        - size: 文件大小（字节），仅文件有此字段\n        - name: 文件名或目录名\n    没有文件则返回空列表 []\n",
            "parameters": {
                "properties": {
                    "dir_path": {
                        "default": null,
                        "title": "dir_path",
                        "type": "string"
                    },
                    "search_mode": {
                        "default": "file",
                        "title": "search_mode",
                        "type": "string"
                    },
                    "file_type": {
                        "default": null,
                        "title": "file_type",
                        "type": "string"
                    },
                    "depth": {
                        "default": 0,
                        "title": "Depth",
                        "type": "integer"
                    }
                },
                "title": "list_dir_itemArguments",
                "type": "object"
            }
        }
    },
